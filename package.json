{
  "name": "anthonyta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first --no-network-family-autoselection' next dev",
    "build": "NODE_OPTIONS='--dns-result-order=ipv4first --no-network-family-autoselection' next build",
    "start": "next start",
    "lint": "eslint",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vault-sync": "node --dns-result-order=ipv4first --no-network-family-autoselection --env-file=.env.local --import tsx scripts/vault-sync.ts",
    "hub-backup": "node --dns-result-order=ipv4first --no-network-family-autoselection --env-file=.env.local --import tsx scripts/hub-backup.ts"
  },
  "dependencies": {
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.2",
    "aws4fetch": "^1.0.20",
    "hash-wasm": "4.12.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.19"
    },
    "next-auth": {
      "@simplewebauthn/browser": "$@simplewebauthn/browser",
      "@simplewebauthn/server": "$@simplewebauthn/server"
    },
    "@auth/core": {
      "@simplewebauthn/browser": "$@simplewebauthn/browser",
      "@simplewebauthn/server": "$@simplewebauthn/server"
    }
  }
}
